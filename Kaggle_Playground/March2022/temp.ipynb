   "metadata": {},
   "outputs": [],
   "source": [
    "from sympy import *"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [],
   "source": [
    "k = Symbol('k')\n",
    "h = Symbol('h')\n",
    "\n",
    "M = Matrix([[exp(k+h), exp(-k)], [exp(-k), exp(k-h)]])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/latex": [
       "$\\displaystyle \\left[\\begin{matrix}e^{h + k} & e^{- k}\\\\e^{- k} & e^{- h + k}\\end{matrix}\\right]$"
      ],
      "text/plain": [
       "Matrix([\n",
       "[exp(h + k),     exp(-k)],\n",
       "[   exp(-k), exp(-h + k)]])"
      ]
     },
     "execution_count": 4,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "M"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/latex": [
       "$\\displaystyle \\lambda^{2} - \\lambda e^{- h + k} - \\lambda e^{h + k} + e^{- h + k} e^{h + k} - e^{- 2 k}$"
      ],
      "text/plain": [
       "lambda**2 - lambda*exp(-h + k) - lambda*exp(h + k) + exp(-h + k)*exp(h + k) - exp(-2*k)"
      ]
     },
     "execution_count": 5,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "lambd = Symbol('lambda')\n",
    "eq = det(M-lambd*eye(2))\n",
    "eq"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/latex": [
       "$\\displaystyle \\frac{\\left(- \\sqrt{\\left(4 e^{2 h} + e^{4 k} - 2 e^{2 h + 4 k} + e^{4 h + 4 k}\\right) e^{2 k}} + e^{3 k} + e^{2 h + 3 k}\\right) e^{- h - 2 k}}{2}$"
      ],
      "text/plain": [
       "(-sqrt((4*exp(2*h) + exp(4*k) - 2*exp(2*h + 4*k) + exp(4*h + 4*k))*exp(2*k)) + exp(3*k) + exp(2*h + 3*k))*exp(-h - 2*k)/2"
      ]
     },
     "execution_count": 7,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "sols = solve(eq, lambd)\n",
    "sols[0]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/latex": [
       "$\\displaystyle \\frac{\\left(\\sqrt{\\left(4 e^{2 h} + e^{4 k} - 2 e^{2 h + 4 k} + e^{4 h + 4 k}\\right) e^{2 k}} + e^{3 k} + e^{2 h + 3 k}\\right) e^{- h - 2 k}}{2}$"
      ],
      "text/plain": [
       "(sqrt((4*exp(2*h) + exp(4*k) - 2*exp(2*h + 4*k) + exp(4*h + 4*k))*exp(2*k)) + exp(3*k) + exp(2*h + 3*k))*exp(-h - 2*k)/2"
      ]
     },
     "execution_count": 8,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "sols[1]"
   ]
